# Dockerfile for running fake-tcp integration tests
#
# Requires privileged mode for network namespace management:
#   docker build -f Dockerfile.test -t phantun-test .
#   docker run --privileged phantun-test

FROM rust:latest

# Install iproute2 for TUN/network namespace management (ip netns, ip link, etc.)
# Install iptables for DNAT rules required by integration tests (Phantun server
# needs DNAT to redirect incoming TCP from the veth to the TUN peer address).
RUN apt-get update && apt-get install -y iproute2 iptables && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# --- Dependency cache layer ---
# Copy only manifest files so this layer is invalidated only when deps change,
# not when source code changes.
COPY Cargo.toml Cargo.lock ./
COPY fake-tcp/Cargo.toml fake-tcp/Cargo.toml
COPY phantun/Cargo.toml phantun/Cargo.toml

# Create stub lib/main files so cargo can resolve and download all dependencies
RUN mkdir -p fake-tcp/src phantun/src phantun/src/bin && \
    echo '' > phantun/src/lib.rs && \
    echo 'fn main() {}' > phantun/src/bin/client.rs && \
    echo 'fn main() {}' > phantun/src/bin/server.rs && \
    echo '' > fake-tcp/src/lib.rs && \
    cargo build -p fake-tcp --features integration-tests 2>/dev/null || true && \
    rm -rf fake-tcp/src phantun/src

# --- Source layer ---
# Copy the real source (invalidates the layer above only when source changes)
COPY . .

# The dependency-cache step compiled stub (empty) lib.rs files. Cargo fingerprints
# for our crates are now stale and may cause integration test binaries to link
# against the empty stubs. Remove fingerprints for our crates only (preserving
# compiled dependencies) so cargo rebuilds fake-tcp and phantun from real source.
RUN rm -rf target/debug/.fingerprint/fake-tcp-* target/debug/.fingerprint/phantun-*

# Build test binaries (caches the compilation, separate from running)
RUN cargo build -p fake-tcp --features integration-tests --tests

# Run integration tests by default
CMD ["cargo", "test", "-p", "fake-tcp", "--features", "integration-tests"]
